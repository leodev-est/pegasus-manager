generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String     @id @default(uuid())
  name                String
  username            String     @unique
  email               String?    @unique
  password            String
  active              Boolean    @default(true)
  mustChangePassword  Boolean    @default(false)
  athleteId           String?    @unique
  avatarUrl           String?
  googleRefreshToken  String?
  googleCalendarId    String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  athlete             Athlete?   @relation(fields: [athleteId], references: [id], onDelete: SetNull)
  roles               UserRole[]
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Athlete {
  id                   String    @id @default(uuid())
  name                 String
  email                String?
  phone                String?
  birthDate            DateTime?
  category             String?
  position             String?
  gender               String?
  status               String    @default("teste")
  activatedAt          DateTime?
  monthlyPaymentStatus String    @default("pendente")
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  payments             Payment[]
  user                 User?
  attendances          TrainingAttendance[]
  evaluations          AthleteEvaluation[]
  application          AthleteApplication?
  paymentStatusHistory PaymentStatusHistory[]
  uniformDeliveries    UniformDelivery[]
  jerseyAssignment     JerseyAssignment?
  trainingFeedbacks    TrainingFeedback[]
  gameConvocations     GameConvocation[]
  injuries             Injury[]
  trainingPlans        TrainingPlan[]
}

model AthleteApplication {
  id                 String    @id @default(uuid())
  name               String
  email              String?
  phone              String?
  birthDate          DateTime?
  category           String?
  position           String?
  availableSaturdays Boolean?
  currentTeam        Boolean?
  currentTeamName    String?
  experienceTime     String?
  level              String?
  willingToCompete   Boolean?
  motivation         String?
  howFound           String?
  referral           String?
  contribution       String?
  source             String    @default("site")
  status             String    @default("pendente")
  notes              String?
  athleteId          String?   @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  athlete            Athlete?  @relation(fields: [athleteId], references: [id], onDelete: SetNull)
}

model Payment {
  id          String    @id @default(uuid())
  athleteId   String?
  description String
  amount      Decimal   @db.Decimal(10, 2)
  type        String
  category    String?
  status      String    @default("pendente")
  dueDate     DateTime?
  paidAt         DateTime?
  referenceMonth String?
  createdAt      DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  athlete     Athlete?  @relation(fields: [athleteId], references: [id], onDelete: SetNull)

  @@index([athleteId])
  @@index([status])
  @@index([referenceMonth])
  @@index([dueDate])
}

model CashMovement {
  id          String   @id @default(uuid())
  description String
  amount      Decimal  @db.Decimal(10, 2)
  type        String
  category    String?
  date        DateTime
  responsible String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id             String    @id @default(uuid())
  title          String
  description    String?
  status         String    @default("todo")
  area           String    @default("management")
  assignedTo     String?
  dueDate        DateTime?
  priority       String    @default("media")
  channel        String?
  labels         Json      @default("[]")
  comments       Json      @default("[]")
  checklist      Json      @default("[]")
  approvalStatus String?
  scheduledAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model TrainingSetting {
  id                       String   @id @default("singleton")
  blockedDates             String[]
  blockedDateEventIds      Json     @default("{}")
  trainingTime             String   @default("17:30 às 19:00")
  trainingLocation         String   @default("Jerusalém")
  trainingDependency       String   @default("Quadra - CREC")
  trainingDaysOfWeek       String[] @default([])
  trainingDuration         Int      @default(90)
  defaultTrainingCategory  String   @default("geral")
  monthlyFeeAmount         Decimal  @default(0) @db.Decimal(10, 2)
  overduePaymentDays       Int      @default(10)
  maxAbsencesPercentage    Float    @default(25)
  minAttendanceToEvaluate  Int      @default(3)
  notifyOnApproval         Boolean  @default(true)
  notifyOnOverdue          Boolean  @default(true)
  notifyOnTraining         Boolean  @default(false)
  systemName               String   @default("Pegasus Manager")
  timezone                 String   @default("America/Sao_Paulo")
  googleCalendarId         String?
  googleRefreshToken       String?
  pixKey                   String?
  pixProvider              String?
  pixApiKey                String?
  pixWebhookSecret         String?
  emailEnabled             Boolean  @default(false)
  emailFallbackEnabled     Boolean  @default(false)
  emailHost                String?
  emailPort                Int?
  emailSecure              Boolean  @default(true)
  emailUser                String?
  emailPassword            String?
  emailFrom                String?
  emailFromName            String   @default("Pegasus Manager")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Training {
  id             String   @id @default(uuid())
  date           DateTime
  title          String
  category       String?
  objective      String?
  warmup         String?
  fundamentals   String?
  mainPart       String?
  reducedGame    String?
  finalPart      String?
  notes          String?
  createdBy      String
  googleEventId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  attendances    TrainingAttendance[]
  feedbacks      TrainingFeedback[]
}

model TrainingAttendance {
  id          String   @id @default(uuid())
  trainingId  String
  athleteId   String
  status      String   @default("presente")
  checkedInAt DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  training    Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  athlete     Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([trainingId, athleteId])
}

model AthleteEvaluation {
  id           String   @id @default(uuid())
  athleteId    String
  evaluatedBy  String?
  selfRating   Float?
  strengths    String?
  improvements String?
  technical    Float?
  physical     Float?
  tactical     Float?
  mental       Float?
  coachNotes   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  athlete      Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([athleteId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model Formation {
  id        String   @id @default(uuid())
  name      String
  createdBy String
  positions Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model School {
  id          String   @id @default(uuid())
  name        String
  contact     String?
  phone       String?
  email       String?
  region      String?
  status      String   @default("nao_contatada")
  responsible String?
  nextAction  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Spreadsheet {
  id          String   @id @default(uuid())
  name        String
  url         String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AnnouncementTemplate {
  id        String   @id @default(uuid())
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScheduledAnnouncement {
  id          String    @id @default(uuid())
  title       String
  body        String
  target      String    @default("active")
  channel     String    @default("both")
  scheduledAt DateTime
  sentAt      DateTime?
  status      String    @default("pending")
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PaymentStatusHistory {
  id         String   @id @default(uuid())
  athleteId  String
  fromStatus String
  toStatus   String
  changedBy  String
  notes      String?
  createdAt  DateTime @default(now())
  athlete    Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
}

model Game {
  id            String             @id @default(uuid())
  date          DateTime
  opponent      String
  location      String
  scorePegasus  Int
  scoreOpponent Int
  result        String
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  sets          GameSet[]
  convocations  GameConvocation[]
}

model GameConvocation {
  id        String   @id @default(uuid())
  gameId    String
  athleteId String
  status    String   @default("convocado") // convocado | presente | ausente
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([gameId, athleteId])
  @@index([gameId])
  @@index([athleteId])
}

model GameSet {
  id            String  @id @default(uuid())
  gameId        String
  setNumber     Int
  scorePegasus  Int
  scoreOpponent Int
  game          Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, setNumber])
}

model UniformItem {
  id          String            @id @default(uuid())
  name        String
  description String?
  stock       Int               @default(0)
  minStock    Int               @default(3)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deliveries  UniformDelivery[]
}

model UniformDelivery {
  id            String      @id @default(uuid())
  uniformItemId String
  athleteId     String
  quantity      Int         @default(1)
  deliveredAt   DateTime    @default(now())
  notes         String?
  deliveredBy   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  uniformItem   UniformItem @relation(fields: [uniformItemId], references: [id], onDelete: Cascade)
  athlete       Athlete     @relation(fields: [athleteId], references: [id], onDelete: Cascade)
}

model JerseyAssignment {
  id        String  @id @default(uuid())
  number    Int
  gender    String
  athleteId String  @unique
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([number, gender])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MonthlyReport {
  id          String    @id @default(uuid())
  month       String    @unique
  fileName    String
  content     Bytes
  fileSize    Int
  generatedAt DateTime  @default(now())
  sentAt      DateTime?
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  userName  String?
  action    String
  entity    String
  entityId  String?
  meta      Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

model Suggestion {
  id          String   @id @default(uuid())
  message     String
  anonymous   Boolean  @default(false)
  authorId    String?
  authorName  String?
  status      String   @default("pendente")
  response    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model MuralPost {
  id        String   @id @default(uuid())
  title     String
  body      String
  category  String   @default("info")
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Injury {
  id             String    @id @default(uuid())
  athleteId      String
  type           String
  severity       String
  description    String?
  startDate      DateTime
  expectedReturn DateTime?
  returnedAt     DateTime?
  notes          String?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  athlete        Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([athleteId])
}

model TrainingPlan {
  id          String    @id @default(uuid())
  athleteId   String
  title       String
  description String?
  goals       String?
  exercises   Json?
  startDate   DateTime?
  endDate     DateTime?
  active      Boolean   @default(true)
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  athlete     Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([athleteId])
}

model TrainingFeedback {
  id          String   @id @default(uuid())
  trainingId  String
  athleteId   String
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  training    Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  athlete     Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([trainingId, athleteId])
  @@index([trainingId])
  @@index([athleteId])
}
